# ============================
# Required API keys
# ============================
OPENAI_API_KEY=
PINECONE_API_KEY=

# ============================
# Pinecone configuration
# ============================
# Index will be created automatically if it does not exist
PINECONE_INDEX_NAME=steam-reviews
PINECONE_NAMESPACE=steam-reviews

# Filled automatically by setup script (leave blank)
PINECONE_INDEX_HOST=

# ============================
# Local data paths (container)
# ============================
EMBEDDINGS_PARQUET=data/embeddings/steam_review_chunks_with_embeddings.parquet
